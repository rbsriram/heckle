{
  "name": "heckle-dev",
  "version": "0.1.0",
  "type": "module",
  "description": "The live QA co-pilot for agentic development. Talk at your app. Ship better code.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "bin": {
    "heckle": "dist/apps/cli/bin/heckle.js"
  },
  "exports": {
    "./vite-plugin": "./dist/packages/capture/src/vite-plugin.js",
    "./next-plugin": "./dist/packages/capture/src/next-plugin.js",
    "./capture-only": "./dist/packages/capture/src/capture-only.js",
    "./source-loader": "./dist/packages/capture/src/source-loader.cjs"
  },
  "files": [
    "dist/apps/cli/bin",
    "dist/apps/cli/src",
    "dist/packages/capture/src",
    "dist/packages/daemon/src",
    "dist/packages/delivery/src",
    "dist/packages/memory/src",
    "dist/packages/mcp/src",
    "dist/packages/providers/src",
    "dist/packages/replay/src",
    "dist/packages/shared/src",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "heckle": "node apps/cli/bin/heckle.ts",
    "daemon": "node --disable-warning=ExperimentalWarning packages/daemon/src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm run build",
    "test": "node --test \"packages/**/test/**/*.test.ts\" \"apps/**/test/**/*.test.ts\"",
    "prepack": "npm run build",
    "stt:build": "swift build --package-path stt -c release",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "dependencies": {
    "playwright": "1.61.1",
    "rrweb": "2.0.1",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.2"
  }
}
