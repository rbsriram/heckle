# Heckle secrets live ONLY in the daemon's environment, never in code, never in the browser.
# The LOCAL-FIRST default build needs NONE of these (Ollama + local dictation = zero egress).
# Fill these in only when you swap a layer to a cloud provider in heckle.config.ts.

# Drafting (only if drafting.provider = "deepseek")
DEEPSEEK_API_KEY=

# Drafting (only if drafting.provider = "anthropic")
ANTHROPIC_API_KEY=

# Streaming voice (only if voice.provider = "deepgram")
DEEPGRAM_API_KEY=

# Optional: override the daemon port (default 4317)
# HECKLE_PORT=4317
